@model IEnumerable<aplicacion.Models.RecordatorioMoi>
@{
    ViewData["Title"] = "Mis Recordatorios";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1><i class="bi bi-list-check"></i> Mis Recordatorios</h1>
        <!-- Botón placeholder: sin acción, para que tu equipo conecte su formulario -->
        <a href="#" class="btn btn-primary" onclick="return false;">
            <i class="bi bi-plus-circle"></i> Nuevo Recordatorio
        </a>
    </div>

    <div id="recordatoriosList">
        <partial name="ListaRecordatorios" model="Model" />
    </div>
</div>

@section Scripts {
    <script>
        function actualizarLista() {
            fetch('/RecordatoriosMoi/GetLista')
                .then(response => response.text())
                .then(html => {
                    document.getElementById('recordatoriosList').innerHTML = html;
                })
                .catch(err => console.error('Error al actualizar:', err));
        }

        setInterval(actualizarLista, 10000);

        document.addEventListener('visibilitychange', function() {
            if (!document.hidden) actualizarLista();
        });

        document.addEventListener('DOMContentLoaded', function() {
            actualizarLista();
        });
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}